[data]
sysuser="systux"

keylayout="de"

git_email="leo@meinel.dev"
git_name="Leopold Johannes Meinel"
git_signingkey="F0A7BB97CAF49D8CB058BB0A744FDDD73AECC993"
git_gpgsign="true"

# Choose one from: /sys/class/backlight/
backlight_device="amdgpu_bl1"
# See: https://github.com/swaywm/sway/wiki
sway_autostart="""
# Startup
## Authentication and credentials
exec /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec /usr/bin/gnome-keyring-daemon -s
## Notifications
exec /usr/bin/swaync
exec /usr/bin/aa-notify -p -s 1 -w 60 -f /var/log/audit/audit.log
## Graphics tablet
exec "${XDG_CONFIG_HOME}"/sway/scripts/input-graphics-tablet.sh
## Tray
exec /usr/bin/nm-applet
exec /usr/bin/nextcloud --background
## Screen color
exec /usr/bin/gammastep -P

# Reload
## Notifications
exec_always /usr/bin/swaync-client -R
exec_always /usr/bin/swaync-client -rs
## Autotiling
exec_always /usr/bin/autotiling-rs
"""
# See: https://github.com/swaywm/sway/wiki#display-configuration
sway_output="""
# Variables
set $laptop eDP-1
set $left DP-3
set $right HDMI-A-1

# Outputs
## Toggle internal display when lid opens/closes
bindswitch lid:on output $laptop disable
bindswitch lid:off output $laptop enable
## Monitors
output $left res 3840x2160@60.000Hz pos 0 0
output $right res 3840x2160@60.000Hz pos 3840 0
output $laptop res 1920x1080@60.000Hz pos 7680 0

# Workspaces
workspace 1 output $left $laptop $right
workspace 2 output $left $laptop $right
workspace 3 output $left $laptop $right
workspace 4 output $left $laptop $right
workspace 5 output $left $laptop $right
workspace 6 output $right $laptop $left
workspace 7 output $right $laptop $left
workspace 8 output $right $laptop $left
workspace 9 output $right $laptop $left
"""
