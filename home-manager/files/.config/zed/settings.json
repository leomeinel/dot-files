// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "auto_install_extensions": {
    "assembly": true,
    "codebook": true,
    "color-highlight": true,
    "comment": true,
    "dependi": true,
    "editorconfig": true,
    "env": true,
    "git-firefly": true,
    "html": true,
    "lua": true,
    "material-icon-theme": true,
    "nginx": true,
    "nix": true,
    "one-dark-pro": true,
    "php": true,
    "ron": true,
    "sql": true,
    "toml": true,
    "wgsl-wesl": true,
    "xml": true
  },
  "languages": {
    "Nix": {
      "language_servers": ["nixd", "!nil"]
    }
  },
  "prettier": {
    "trailingComma": "none"
  },
  "inline_code_actions": false,
  "toolbar": {
    "code_actions": true
  },
  "icon_theme": "Material Icon Theme",
  "git": {
    "blame": {
      "show_avatar": false
    },
    "inline_blame": {
      "enabled": false
    }
  },
  "git_panel": {
    "file_icons": true
  },
  "tabs": {
    "file_icons": true
  },
  "use_smartcase_search": true,
  "diagnostics": {
    "inline": {
      "enabled": true,
      "max_severity": "warning"
    }
  },
  "colorize_brackets": true,
  "title_bar": {
    "show_user_picture": false,
    "show_onboarding_banner": false,
    "show_sign_in": false
  },
  "inlay_hints": {
    "show_background": false,
    "enabled": true
  },
  "scrollbar": {
    "show": "never"
  },
  "minimap": {
    "current_line_highlight": "all",
    "show": "always"
  },
  "scroll_beyond_last_line": "off",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "auto_update": false,
  "collaboration_panel": {
    "button": false
  },
  "disable_ai": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark Pro"
  }
}
